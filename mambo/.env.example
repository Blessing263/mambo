# ── Mambo Environment Variables ─────────────────────────────────────────────
# Copy this to .env and fill in values for your deployment.
# Never commit the real .env file — it contains secrets.

# ── Required ───────────────────────────────────────────────────────────────

# DeepSeek API key (generation / backbone LLM). Required.
# Obtain from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# PostgreSQL connection string. Required.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://mambo_app:change-me@127.0.0.1:5432/ruzivo

# ── Optional (sensible defaults below) ─────────────────────────────────────

# DeepSeek settings
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash

# Ollama (self-hosted embeddings)
# OLLAMA_BASE_URL=http://localhost:11435
# EMBED_MODEL=qwen3-embedding:8b
# EMBED_DIM=4096

# Allowed CORS origins (comma-separated)
# RUZIVO_ALLOWED_ORIGINS=https://mambo.yttrix.tech,http://localhost:3055

# Environment: "production" disables /docs and enables secure cookies
# RUZIVO_ENV=development

# Web verification (Tavily) — disabled by default (official-source-only)
# RUZIVO_ENABLE_WEB_VERIFY=
# TAVILY_API_KEY=

# Admin seed password (used by scripts/seed_admin.py)
# MAMBO_ADMIN_PASSWORD=
