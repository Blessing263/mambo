# Secrets & local config — NEVER commit
.env
.env.*
!.env.example
.claude/
.secrets/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
*.tsbuildinfo
dist/
build/
out/

# Ingestion artifacts (raw downloaded gov documents — large, re-fetchable)
raw_docs/

# Misc
*.log
.DS_Store
*.tmp
test-results/
.playwright-mcp/
*.png
*.zip

# proposal render intermediate
submission/_proposal.html

# local team contacts (PII) — not for git
submission/*.local.md

# staging area: raw bytes + runtime state stay local; manifests + rules are committable
staging/*/raw/
staging/*/frontier.json
staging/*/.lock
staging/runs.jsonl
staging/acquire.log
